{
  "name": "tsx-sql",
  "version": "0.1.0",
  "description": "Compile TSX SQL fragments into parameterized SQL.",
  "keywords": [
    "sql",
    "tsx",
    "jsx",
    "typescript",
    "mybatis",
    "query-builder"
  ],
  "author": "GuXianWN",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GuXianWN/tsx-sql.git"
  },
  "bugs": {
    "url": "https://github.com/GuXianWN/tsx-sql/issues"
  },
  "homepage": "https://github.com/GuXianWN/tsx-sql#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@9.15.0",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js",
      "require": "./dist/jsx-dev-runtime.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
