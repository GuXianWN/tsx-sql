{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "tsx-sql",
    "baseUrl": ".",
    "paths": {
      "tsx-sql": [
        "./src/index.ts"
      ],
      "tsx-sql/jsx-runtime": [
        "./src/jsx-runtime.ts"
      ],
      "tsx-sql/jsx-dev-runtime": [
        "./src/jsx-dev-runtime.ts"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src",
    "test"
  ]
}
